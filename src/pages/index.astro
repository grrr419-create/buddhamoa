---
import Layout from "../layouts/Layout.astro";
import TopNotice from "../components/TopNotice.astro";
import LandingProductCurationsSection from "../components/LandingProductCurationsSection.astro";
import LandingCategorySection from "../components/LandingCategorySection.astro";
import ProductShortsSection from "../components/ProductShortsSection.astro";
import LandingTempleShortsSection from "../components/LandingTempleShortsSection.astro";
import FaqList from "../components/FaqList.astro";
import SectionHeader from "../components/SectionHeader.astro";
import {
  categories,
  faqs,
  productCurations,
  productShorts,
  siteConfig,
  templeShorts,
  topNotices,
} from "../data/site";
import {
  categoryItemListSchema,
  faqSchema,
  homePageSchema,
  landingNavigationSchemas,
  organizationSchema,
  productCurationItemListSchemas,
  productShortVideoSchemas,
  templeShortVideoSchemas,
  websiteSchema,
} from "../utils/seo";

const title = "불교용품은 역시 붓다모아 | 불상·염주·불교굿즈 안내";
const description =
  "붓다모아는 불상, 염주, 목탁, 명상도구, 사경노트, 불교굿즈를 신행과 일상 용도에 맞게 정리해 소개하는 온라인 불교용품 안내 페이지입니다.";
const productShortsInsertIndex = productCurations.findIndex(
  (curation) => curation.slug === "finger-prayer-beads",
);
const productCurationsBeforeShorts =
  productShortsInsertIndex >= 0
    ? productCurations.slice(0, productShortsInsertIndex + 1)
    : productCurations;
const productCurationsAfterShorts =
  productShortsInsertIndex >= 0 ? productCurations.slice(productShortsInsertIndex + 1) : [];
---

<Layout
  title={title}
  description={description}
  pathname="/"
  structuredData={[
    organizationSchema(),
    websiteSchema(),
    homePageSchema({
      categories,
      curations: productCurations,
      productShorts,
      templeShorts,
      faqItems: faqs,
    }),
    ...landingNavigationSchemas(),
    categoryItemListSchema(categories),
    ...productCurationItemListSchemas(productCurations),
    ...productShortVideoSchemas(productShorts),
    ...templeShortVideoSchemas(templeShorts),
    faqSchema(),
  ]}
>
  <TopNotice notices={topNotices} />

  <LandingCategorySection categories={categories} storeUrl={siteConfig.storeUrl} />
  <LandingProductCurationsSection
    curations={productCurationsBeforeShorts}
    sectionId="product-curations"
  />
  <ProductShortsSection shorts={productShorts} />
  <LandingProductCurationsSection curations={productCurationsAfterShorts} />
  <LandingTempleShortsSection shorts={templeShorts} />

  <section id="guide-faq">
    <SectionHeader title="붓다모아 이용 안내" />
    <FaqList items={faqs} />
  </section>

</Layout>
