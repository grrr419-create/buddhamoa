---
import Layout from "../layouts/Layout.astro";
import TopNotice from "../components/TopNotice.astro";
import LandingProductCurationsSection from "../components/LandingProductCurationsSection.astro";
import LandingCategorySection from "../components/LandingCategorySection.astro";
import ProductShortsSection from "../components/ProductShortsSection.astro";
import LandingTempleShortsSection from "../components/LandingTempleShortsSection.astro";
import LandingTextCurationsSection from "../components/LandingTextCurationsSection.astro";
import MobileInfiniteScroller from "../components/MobileInfiniteScroller.astro";
import FaqList from "../components/FaqList.astro";
import SectionHeader from "../components/SectionHeader.astro";
import {
  categories,
  faqs,
  productCurations,
  productShorts,
  postTempleCurations,
  secondaryNotices,
  siteConfig,
  templeShorts,
  topNotices,
} from "../data/site";
import {
  categoryItemListSchema,
  faqSchema,
  homePageSchema,
  landingNavigationSchemas,
  organizationSchema,
  productCurationItemListSchemas,
  productShortVideoSchemas,
  templeShortVideoSchemas,
  websiteSchema,
} from "../utils/seo";

const title = "불교용품은 역시 붓다모아 | 불상·염주·불교굿즈 안내";
const description =
  "붓다모아는 불상, 염주, 목탁, 명상도구, 사경노트, 불교굿즈를 신행과 일상 용도에 맞게 정리해 소개하는 온라인 불교용품 안내 페이지입니다.";

function splitAfterSlug<Item extends { slug: string }>(items: Item[], slug: string): [Item[], Item[]] {
  const index = items.findIndex((item) => item.slug === slug);

  return index >= 0 ? [items.slice(0, index + 1), items.slice(index + 1)] : [items, []];
}

const afterSecondaryNoticeCurationSlugs = [
  "practice-space-buddha",
  "compassion-symbols",
  "ksitigarbha-for-loved-ones",
];
const afterTempleShortsCurationSlugs = ["laughing-buddha-symbol"];
const afterSecondaryNoticeProductCurations = productCurations.filter(
  (curation) => afterSecondaryNoticeCurationSlugs.includes(curation.slug),
);
const afterTempleShortsProductCurations = productCurations.filter(
  (curation) => afterTempleShortsCurationSlugs.includes(curation.slug),
);
const primaryProductCurations = productCurations.filter(
  (curation) =>
    !afterSecondaryNoticeCurationSlugs.includes(curation.slug) &&
    !afterTempleShortsCurationSlugs.includes(curation.slug),
);
const [productCurationsBeforeShorts, productCurationsAfterShorts] = splitAfterSlug(
  primaryProductCurations,
  "finger-prayer-beads",
);
const postTempleCurationsBeforeTempleShorts = postTempleCurations.slice(0, 0);
const postTempleCurationsAfterTempleShorts = postTempleCurations;
---

<Layout
  title={title}
  description={description}
  pathname="/"
  structuredData={[
    organizationSchema(),
    websiteSchema(),
    homePageSchema({
      categories,
      curations: productCurations,
      productShorts,
      templeShorts,
      faqItems: faqs,
    }),
    ...landingNavigationSchemas(),
    categoryItemListSchema(categories),
    ...productCurationItemListSchemas(productCurations),
    ...productShortVideoSchemas(productShorts),
    ...templeShortVideoSchemas(templeShorts),
    faqSchema(),
  ]}
>
  <TopNotice notices={topNotices} label="공지사항1" sectionId="notice-1" trackPrefix="notice_1" />

  <LandingCategorySection categories={categories} storeUrl={siteConfig.storeUrl} />
  <LandingProductCurationsSection
    curations={productCurationsBeforeShorts}
    sectionId="product-curations"
  />
  <ProductShortsSection shorts={productShorts} />
  <LandingProductCurationsSection curations={productCurationsAfterShorts} />
  <TopNotice notices={secondaryNotices} label="공지사항2" sectionId="notice-2" trackPrefix="notice_2" />
  <LandingProductCurationsSection curations={afterSecondaryNoticeProductCurations} />
  <LandingTextCurationsSection curations={postTempleCurationsBeforeTempleShorts} />
  <LandingTempleShortsSection shorts={templeShorts} />
  <LandingProductCurationsSection curations={afterTempleShortsProductCurations} />
  <LandingTextCurationsSection curations={postTempleCurationsAfterTempleShorts} />
  <MobileInfiniteScroller />

  <section id="guide-faq">
    <SectionHeader title="붓다모아 이용 안내" />
    <FaqList items={faqs} />
  </section>

</Layout>
