---
import Layout from "../layouts/Layout.astro";
import {
  curationProductDetails,
  getCurationProductDetailPath,
} from "../data/curationProductDetails";

const title = "조회수 통계 | 붓다모아";
const description = "붓다모아 관리자용 비공개 조회수 통계 페이지입니다.";
const statsPageLabelEntries = [
  ["/", "홈"],
  ["/contact/", "문의"],
  ["/privacy/", "개인정보처리방침"],
  ...curationProductDetails.map((detail) => [
    getCurationProductDetailPath(detail.curationSlug, detail.productSlug),
    detail.name,
  ]),
];
const statsPageLabelJson = JSON.stringify(statsPageLabelEntries).replaceAll("<", "\\u003c");
---

<Layout
  title={title}
  description={description}
  pathname="/stats/"
  robots="noindex,nofollow,noarchive"
  showHeader={false}
  showMobileShare={false}
>
  <section class="panel stats-dashboard" data-stats-dashboard>
    <div class="stats-dashboard__head">
      <div>
        <p class="eyebrow">Private Stats</p>
        <h1>조회수 통계</h1>
      </div>
      <div class="stats-dashboard__actions" data-stats-session hidden>
        <span class="stats-dashboard__user" data-stats-user></span>
        <button class="button-secondary" type="button" data-stats-refresh>새로고침</button>
        <button class="button-secondary" type="button" data-stats-logout>로그아웃</button>
      </div>
    </div>

    <p class="body-copy">
      Supabase Auth로 로그인한 허용 관리자만 조회할 수 있습니다.
    </p>

    <div class="stats-alert" data-stats-message hidden></div>

    <form class="stats-login" data-stats-login>
      <label for="stats-email">관리자 이메일</label>
      <div class="stats-login__row">
        <input
          id="stats-email"
          name="email"
          type="email"
          autocomplete="email"
          placeholder="admin@example.com"
          required
          data-stats-email
        />
        <button class="button" type="submit">로그인 링크 받기</button>
      </div>
    </form>

    <div class="stats-content" data-stats-content hidden>
      <div class="stats-toolbar" aria-label="통계 조회 옵션">
        <div class="stats-date-controls">
          <span class="stats-date-controls__label">조회 기간</span>
          <label class="stats-control" for="stats-start-date">
            <span>시작</span>
            <input id="stats-start-date" type="date" data-stats-start-date />
          </label>
          <span class="stats-date-controls__separator" aria-hidden="true">~</span>
          <label class="stats-control" for="stats-end-date">
            <span>종료</span>
            <input id="stats-end-date" type="date" data-stats-end-date />
          </label>
        </div>

        <fieldset class="stats-segmented" data-stats-granularity>
          <legend>분석 단위</legend>
          <label>
            <input type="radio" name="stats-granularity" value="day" checked />
            <span>일</span>
          </label>
          <label>
            <input type="radio" name="stats-granularity" value="week" />
            <span>주</span>
          </label>
          <label>
            <input type="radio" name="stats-granularity" value="month" />
            <span>월</span>
          </label>
        </fieldset>
      </div>

      <div class="stats-summary">
        <article class="stats-card">
          <span>오늘</span>
          <strong data-stats-total="today">—</strong>
          <small data-stats-total="today-visitors">순방문자 —</small>
        </article>
        <article class="stats-card">
          <span>전체</span>
          <strong data-stats-total="total">—</strong>
          <small data-stats-total="total-visitors">순방문자 —</small>
        </article>
        <article class="stats-card">
          <span>선택 범위</span>
          <strong data-stats-total="selected">—</strong>
          <small data-stats-total="selected-visitors">순방문자 —</small>
        </article>
        <article class="stats-card">
          <span>단위 평균</span>
          <strong data-stats-total="average">—</strong>
        </article>
      </div>

      <section class="stats-panel stats-panel--wide">
        <div class="stats-panel__head">
          <h2 data-stats-trend-title>조회수 추이</h2>
          <span data-stats-trend-meta></span>
        </div>
        <div class="stats-chart" data-stats-trend-chart></div>
      </section>

      <div class="stats-grid">
        <section class="stats-panel">
          <h2>유입 도메인</h2>
          <div class="stats-bars" data-stats-referrer-bars></div>
          <p class="stats-chart__caption" data-stats-referrer-total></p>
        </section>

        <section class="stats-panel">
          <h2>인기 페이지</h2>
          <div class="stats-bars" data-stats-path-bars></div>
        </section>

        <section class="stats-panel">
          <h2>UTM 캠페인</h2>
          <div class="stats-table-wrap">
            <table class="stats-table">
              <thead>
                <tr>
                  <th scope="col">소스 / 매체 / 캠페인</th>
                  <th scope="col">조회수</th>
                </tr>
              </thead>
              <tbody data-stats-utm></tbody>
            </table>
          </div>
        </section>

        <section class="stats-panel">
          <h2>기기 구분</h2>
          <div class="stats-table-wrap">
            <table class="stats-table">
              <thead>
                <tr>
                  <th scope="col">기기</th>
                  <th scope="col">조회수</th>
                </tr>
              </thead>
              <tbody data-stats-devices></tbody>
            </table>
          </div>
        </section>
      </div>

      <p class="stats-updated" data-stats-updated></p>
    </div>
  </section>

  <script type="application/json" data-stats-page-labels set:html={statsPageLabelJson}></script>
</Layout>

<script>
  import "../scripts/statsDashboard.ts";
</script>
