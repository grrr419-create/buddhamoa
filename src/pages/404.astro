---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../utils/paths";

const title = "페이지를 찾을 수 없습니다 | 붓다모아";
const description =
  "요청하신 페이지를 찾을 수 없습니다. 붓다모아 홈에서 불교용품 안내를 다시 확인하세요.";
---

<Layout
  title={title}
  description={description}
  pathname="/404/"
  robots="noindex,follow"
  showMobileShare={false}
>
  <section class="detail-grid">
    <div class="panel detail-copy">
      <div>
        <p class="eyebrow">404</p>
        <h1>페이지를 찾을 수 없습니다</h1>
      </div>
      <p class="body-copy">
        주소가 바뀌었거나 삭제된 페이지일 수 있습니다. 홈으로 돌아가 붓다모아의 불교용품 안내를
        다시 확인해 주세요.
      </p>
      <div class="stack-inline">
        <a class="button" href={withBase("/")}>홈으로 돌아가기</a>
      </div>
    </div>
  </section>
</Layout>
