---
import Layout from "../../layouts/Layout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { products } from "../../data/products";
import { siteConfig } from "../../data/site";
import { productSchema } from "../../utils/seo";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const relatedProducts = products
  .filter(
    (candidate) =>
      candidate.slug !== product.slug && candidate.category === product.category,
  )
  .slice(0, 3);

const title = `${product.name} | ${siteConfig.brandName}`;
const description = `${product.summary} ${product.description[0]}`;
---

<Layout
  title={title}
  description={description}
  pathname={`/products/${product.slug}/`}
  image={product.image}
  structuredData={[productSchema(product)]}
>
  <section class="detail-grid">
    <div class="panel detail-copy">
      <img src={product.image} alt={product.imageAlt} />
      <span class="meta-chip">{product.category}</span>
      <h1>{product.name}</h1>
      {product.description.map((paragraph) => <p>{paragraph}</p>)}

      <div class="stack-inline">
        <a class="button" href={product.storeUrl} data-track={`product_detail_${product.slug}`}>
          스마트스토어에서 보기
        </a>
        <a class="button-secondary" href="/">홈으로 돌아가기</a>
      </div>
    </div>

    <aside class="detail-sidebar">
      <div class="detail-card">
        <p class="meta-chip">핵심 포인트</p>
        <ul class="highlight-list">
          {product.highlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
      </div>

      <div class="detail-card">
        <p class="meta-chip">이런 분께 추천</p>
        <dl class="meta-list">
          <dt>추천 상황</dt>
          <dd>{product.targetUse}</dd>
          <dt>검색 의도</dt>
          <dd>{product.keywords.join(", ")}</dd>
        </dl>
      </div>
    </aside>
  </section>

  {relatedProducts.length > 0 && (
    <section>
      <div class="section-head">
        <div>
          <p class="eyebrow">Related Picks</p>
          <h2>같이 보면 좋은 상품</h2>
        </div>
      </div>
      <div class="product-grid">
        {relatedProducts.map((relatedProduct) => <ProductCard product={relatedProduct} />)}
      </div>
    </section>
  )}
</Layout>
