---
import SeoHead from "../components/SeoHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  pathname: string;
  image?: string;
  robots?: string;
  structuredData?: Record<string, unknown>[];
};

const { title, description, pathname, image, robots, structuredData = [] } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <SeoHead
      title={title}
      description={description}
      pathname={pathname}
      image={image}
      robots={robots}
      structuredData={structuredData}
    />
  </head>
  <body>
    <div class="site-shell">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <script is:inline>
      (() => {
        window.__buddhamoaAnalytics = window.__buddhamoaAnalytics || [];

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const link = target.closest("a[data-track]");
          if (!(link instanceof HTMLAnchorElement)) return;

          const detail = {
            event: "buddhamoa_outbound_click",
            label: link.dataset.track || "unknown",
            href: link.href,
            text: (link.textContent || "").trim(),
            timestamp: new Date().toISOString(),
          };

          window.__buddhamoaAnalytics.push(detail);
          window.dataLayer?.push(detail);

          if (typeof window.gtag === "function") {
            window.gtag("event", "click", {
              event_category: "outbound_link",
              event_label: detail.label,
              link_url: detail.href,
            });
          }

          window.dispatchEvent(
            new CustomEvent("buddhamoa:outbound-click", { detail }),
          );
        });
      })();
    </script>
  </body>
</html>
