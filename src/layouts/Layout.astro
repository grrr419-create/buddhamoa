---
import SeoHead from "../components/SeoHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileShareButton from "../components/MobileShareButton.astro";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  pathname: string;
  image?: string;
  robots?: string;
  structuredData?: Record<string, unknown>[];
};

const { title, description, pathname, image, robots, structuredData = [] } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <SeoHead
      title={title}
      description={description}
      pathname={pathname}
      image={image}
      robots={robots}
      structuredData={structuredData}
    />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-B0W8ZHEDM8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-B0W8ZHEDM8");
    </script>
  </head>
  <body>
    <div class="site-shell">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
      <MobileShareButton />
    </div>

    <script is:inline>
      (() => {
        window.__buddhamoaAnalytics = window.__buddhamoaAnalytics || [];

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const link = target.closest("a[data-track]");
          if (!(link instanceof HTMLAnchorElement)) return;

          const detail = {
            event: "buddhamoa_outbound_click",
            label: link.dataset.track || "unknown",
            href: link.href,
            text: (link.textContent || "").trim(),
            timestamp: new Date().toISOString(),
          };

          window.__buddhamoaAnalytics.push(detail);
          window.dataLayer?.push(detail);

          if (typeof window.gtag === "function") {
            window.gtag("event", "click", {
              event_category: "outbound_link",
              event_label: detail.label,
              link_url: detail.href,
            });
          }

          window.dispatchEvent(
            new CustomEvent("buddhamoa:outbound-click", { detail }),
          );
        });
      })();
    </script>
  </body>
</html>
