---
import type { ChannelLink } from "../types";

type Props = {
  channels: ChannelLink[];
};

type HeaderIcon = ChannelLink["icon"];

type HeaderNavItem = {
  label: string;
  shortLabel: string;
  href: string;
  icon: HeaderIcon;
  track: string;
  external?: boolean;
};

const { channels } = Astro.props;

const navItems: HeaderNavItem[] = channels.map((channel) => ({
  label: channel.label,
  shortLabel:
    channel.icon === "store"
      ? "스토어"
      : channel.icon === "blog"
        ? "블로그"
        : channel.icon === "instagram"
          ? "인스타"
          : channel.label,
  href: channel.href,
  icon: channel.icon,
  track: `header_${channel.icon}`,
  external: true,
}));

const icons: Record<HeaderIcon, string> = {
  store:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.2 8.2V6.9a4.8 4.8 0 0 1 9.6 0v1.3"/><path d="M5.4 8.2h13.2l-.8 11.1a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5.4 8.2Z"/><path d="M8.6 11.5c.8 1.2 1.9 1.9 3.4 1.9s2.6-.7 3.4-1.9"/></svg>',
  blog:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4.6h14a2 2 0 0 1 2 2v9.6a2 2 0 0 1-2 2H9.6L5 21.2v-3a2 2 0 0 1-2-2V6.6a2 2 0 0 1 2-2Z"/><path d="M7.6 9h6.8"/><path d="M7.6 12.3h8.8"/><path d="M7.6 15.6h5.4"/></svg>',
  youtube:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 8.2a3 3 0 0 0-2.1-2.1C17.1 5.6 12 5.6 12 5.6s-5.1 0-6.9.5A3 3 0 0 0 3 8.2a31.3 31.3 0 0 0 0 7.6 3 3 0 0 0 2.1 2.1c1.8.5 6.9.5 6.9.5s5.1 0 6.9-.5a3 3 0 0 0 2.1-2.1 31.3 31.3 0 0 0 0-7.6Z"/><path d="m10.3 14.8 4.4-2.8-4.4-2.8v5.6Z"/></svg>',
  instagram:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4.3" y="4.3" width="15.4" height="15.4" rx="4.4"/><circle cx="12" cy="12" r="3.5"/><circle cx="16.7" cy="7.5" r=".8"/></svg>',
  tiktok:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14.2 4.3v9.5a4.4 4.4 0 1 1-4.4-4.4c.4 0 .8.1 1.2.2v3.1a1.6 1.6 0 1 0 1.1 1.5V4.3h2.1Z"/><path d="M14.2 4.3c.5 2.8 2.1 4.5 4.8 5v3.1c-1.8-.1-3.4-.7-4.8-1.8"/></svg>',
};
---

<nav class="site-nav-icons" aria-label="주요 메뉴와 외부 채널">
  {
    navItems.map((item) => (
      <a
        class={`site-nav-icon ${item.icon === "store" ? "site-nav-icon--store" : ""}`}
        href={item.href}
        aria-label={`${item.label} 바로가기`}
        title={`${item.label} 바로가기`}
        data-track={item.track}
        target={item.external ? "_blank" : undefined}
        rel={item.external ? "noreferrer" : undefined}
      >
        <span class="site-nav-icon__glyph" set:html={icons[item.icon]} />
        <span class="site-nav-icon__label">{item.shortLabel}</span>
      </a>
    ))
  }
</nav>
