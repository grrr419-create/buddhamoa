---
import type { CategoryLink } from "../types";
import CategoryGrid from "./CategoryGrid.astro";
import LandingSectionPanel from "./LandingSectionPanel.astro";
import StoreCtaButton from "./StoreCtaButton.astro";

type Props = {
  categories: CategoryLink[];
  storeUrl: string;
};

const { categories, storeUrl } = Astro.props;
---

<LandingSectionPanel
  id="category-links"
  tone="category"
  title="필요한 불교용품, 쉽게 골라보세요"
  description="마음이 가는 물건을 편하게 둘러보세요."
>
  <Fragment slot="header-actions">
    <StoreCtaButton href={storeUrl} track="category_store" />
  </Fragment>
  <CategoryGrid categories={categories} />
</LandingSectionPanel>
