---
import { absoluteUrl } from "../utils/seo";
import { withBase } from "../utils/paths";
import { siteConfig } from "../data/site";

type Props = {
  title: string;
  description: string;
  pathname: string;
  image?: string;
  robots?: string;
  structuredData?: Record<string, unknown>[];
};

const {
  title,
  description,
  pathname,
  image = "/images/brand/new-og-image.png",
  robots = "index,follow,max-image-preview:large",
  structuredData = [],
} = Astro.props;

const canonical = absoluteUrl(pathname);
const imageUrl = absoluteUrl(image);
const faviconPath = withBase("/images/brand/파비콘.png");
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<meta name="keywords" content={siteConfig.keywords.join(", ")} />
<meta name="naver-site-verification" content="1bff0ef94206f4be397a9c4d74df6be3fede09c0" />
<meta name="robots" content={robots} />
<link rel="icon" type="image/png" href={faviconPath} />
<link rel="shortcut icon" type="image/png" href={faviconPath} />
<link rel="apple-touch-icon" href={faviconPath} />
<link rel="canonical" href={canonical} />
<title>{title}</title>

<meta property="og:type" content="website" />
<meta property="og:locale" content="ko_KR" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1731" />
<meta property="og:image:height" content="909" />
<meta property="og:site_name" content="붓다모아" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

{
  structuredData.map((item) => (
    <script type="application/ld+json" set:html={JSON.stringify(item)} />
  ))
}
