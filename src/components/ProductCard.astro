---
import type { Product } from "../types";
import { withBase } from "../utils/paths";
import OptimizedImage from "./OptimizedImage.astro";

type Props = {
  product: Product;
};

const { product } = Astro.props;
---

<article class="product-card">
  <a class="product-card__image" href={withBase(`/products/${product.slug}/`)}>
    <OptimizedImage
      src={product.image}
      alt={product.imageAlt}
      width="720"
      height="720"
      loading="lazy"
      sizes="(max-width: 760px) 82vw, 320px"
      optimizedWidths={[320, 480, 720]}
    />
  </a>
  <p class="product-card__category">{product.category}</p>
  <h3>
    <a href={withBase(`/products/${product.slug}/`)}>{product.name}</a>
  </h3>
  <p class="product-card__summary">{product.summary}</p>
  <div class="product-card__actions">
    <a class="product-card__link" href={withBase(`/products/${product.slug}/`)}>
      자세히 읽기
    </a>
    <a
      class="product-card__store"
      href={product.storeUrl}
      data-track={`product_card_${product.slug}`}
      target="_blank"
      rel="nofollow noopener noreferrer"
    >
      구매처 보기
    </a>
  </div>
</article>
