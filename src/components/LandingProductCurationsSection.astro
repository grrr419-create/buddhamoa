---
import type { ProductCuration } from "../types";
import {
  getCurationProductDetailPath,
  hasCurationProductDetail,
} from "../data/curationProductDetails";
import { withBase } from "../utils/paths";
import OptimizedImage from "./OptimizedImage.astro";

type Props = {
  curations: ProductCuration[];
  sectionId?: string;
};

const { curations, sectionId } = Astro.props;

const getItemHref = (curation: ProductCuration, item: ProductCuration["items"][number]) =>
  hasCurationProductDetail(curation.slug, item.slug)
    ? withBase(getCurationProductDetailPath(curation.slug, item.slug))
    : item.href;
---

{curations.length > 0 && (
  <section id={sectionId} class="product-curations" aria-label="붓다모아 상품 큐레이션">
    {curations.map((curation, curationIndex) => (
      <section
        class={`product-curation${curationIndex % 2 === 1 ? " product-curation--reverse" : ""}`}
        aria-labelledby={`product-curation-${curation.slug}`}
      >
        <h2 class="product-curation__title" id={`product-curation-${curation.slug}`}>
          {curation.name}
        </h2>
        <p class="product-curation__description">{curation.description}</p>

        <div class="product-curation__viewport">
          <div class="product-curation__track">
            <div class="product-curation__group">
              {curation.items.map((item, itemIndex) => (
                <a
                  class="product-curation-card"
                  href={getItemHref(curation, item)}
                  aria-label={
                    hasCurationProductDetail(curation.slug, item.slug)
                      ? `${item.name} 상세 설명 보기`
                      : `${item.name} 상품 보러가기`
                  }
                  data-track={`product_curation_${curation.slug}_${item.slug}`}
                  target={hasCurationProductDetail(curation.slug, item.slug) ? undefined : "_blank"}
                  rel={
                    hasCurationProductDetail(curation.slug, item.slug)
                      ? undefined
                      : "nofollow noopener noreferrer"
                  }
                >
                  <span class="product-curation-card__image-wrap">
                    <OptimizedImage
                      class="product-curation-card__image"
                      src={item.image}
                      alt={item.imageAlt}
                      width="720"
                      height="720"
                      loading={curationIndex === 0 && itemIndex === 0 ? "eager" : "lazy"}
                      fetchpriority={curationIndex === 0 && itemIndex === 0 ? "high" : "auto"}
                      sizes="(max-width: 860px) 72vw, (max-width: 1040px) 20vw, 180px"
                      optimizedWidths={[320, 480, 720]}
                    />
                  </span>
                  <span class="product-curation-card__name">{item.name}</span>
                </a>
              ))}
            </div>
            <div class="product-curation__group" aria-hidden="true">
              {curation.items.map((item) => (
                <article
                  class="product-curation-card"
                  data-track={`product_curation_${curation.slug}_${item.slug}`}
                >
                  <span class="product-curation-card__image-wrap">
                    <OptimizedImage
                      class="product-curation-card__image"
                      src={item.image}
                      alt={item.imageAlt}
                      width="720"
                      height="720"
                      loading="lazy"
                      sizes="(max-width: 860px) 72vw, (max-width: 1040px) 20vw, 180px"
                      optimizedWidths={[320, 480, 720]}
                    />
                  </span>
                  <span class="product-curation-card__name">{item.name}</span>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>
    ))}
  </section>
)}
