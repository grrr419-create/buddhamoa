---
import type { ProductCuration } from "../types";
import { withBase } from "../utils/paths";

type Props = {
  curations: ProductCuration[];
};

const { curations } = Astro.props;
---

{curations.length > 0 && (
  <section class="product-curations" aria-label="붓다모아 상품 큐레이션">
    {curations.map((curation, curationIndex) => (
      <section
        class={`product-curation${curationIndex % 2 === 1 ? " product-curation--reverse" : ""}`}
        aria-labelledby={`product-curation-${curation.slug}`}
      >
        <h2 class="product-curation__title" id={`product-curation-${curation.slug}`}>
          {curation.name}
        </h2>

        <div class="product-curation__viewport">
          <div class="product-curation__track">
            <div class="product-curation__group">
              {curation.items.map((item, itemIndex) => (
                <a
                  class="product-curation-card"
                  href={item.href}
                  aria-label={`${item.name} 상품 보러가기`}
                  data-track={`product_curation_${curation.slug}_${item.slug}`}
                  target="_blank"
                  rel="noreferrer"
                >
                  <span class="product-curation-card__image-wrap">
                    <img
                      class="product-curation-card__image"
                      src={withBase(item.image)}
                      alt={item.imageAlt}
                      width="720"
                      height="720"
                      loading={curationIndex === 0 && itemIndex === 0 ? "eager" : "lazy"}
                    />
                  </span>
                  <span class="product-curation-card__name">{item.name}</span>
                </a>
              ))}
            </div>
            <div class="product-curation__group" aria-hidden="true">
              {curation.items.map((item) => (
                <a
                  class="product-curation-card"
                  href={item.href}
                  aria-label={`${item.name} 상품 보러가기`}
                  data-track={`product_curation_${curation.slug}_${item.slug}`}
                  target="_blank"
                  rel="noreferrer"
                  tabindex="-1"
                >
                  <span class="product-curation-card__image-wrap">
                    <img
                      class="product-curation-card__image"
                      src={withBase(item.image)}
                      alt={item.imageAlt}
                      width="720"
                      height="720"
                      loading="lazy"
                    />
                  </span>
                  <span class="product-curation-card__name">{item.name}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    ))}
  </section>
)}

<script>
  const mobileCurationQuery = window.matchMedia("(max-width: 767px)");
  const reducedMotionCurationQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
  const activeCurationScrollers = new Map();

  const getCurationLoopWidth = (viewport) => {
    const group = viewport.querySelector(".product-curation__group");

    if (!(group instanceof HTMLElement)) {
      return 0;
    }

    return group.getBoundingClientRect().width;
  };

  const createCurationScroller = (viewport) => {
    const section = viewport.closest(".product-curation");
    const direction = section?.classList.contains("product-curation--reverse") ? -1 : 1;
    const speed = 24;
    let loopWidth = 0;
    let frameId = 0;
    let resumeTimer = 0;
    let lastTime = 0;
    let isPaused = false;

    const measure = () => {
      loopWidth = getCurationLoopWidth(viewport);

      if (direction < 0 && loopWidth > 0 && viewport.scrollLeft < 1) {
        viewport.scrollLeft = loopWidth;
      }
    };

    const normalize = () => {
      if (loopWidth <= 0) {
        return;
      }

      if (viewport.scrollLeft >= loopWidth) {
        viewport.scrollLeft -= loopWidth;
      } else if (viewport.scrollLeft <= 0) {
        viewport.scrollLeft += loopWidth;
      }
    };

    const pause = () => {
      isPaused = true;
      window.clearTimeout(resumeTimer);
    };

    const resumeSoon = () => {
      window.clearTimeout(resumeTimer);
      resumeTimer = window.setTimeout(() => {
        isPaused = false;
        lastTime = 0;
      }, 1800);
    };

    const pauseTemporarily = () => {
      pause();
      resumeSoon();
    };

    const tick = (now) => {
      if (!mobileCurationQuery.matches || reducedMotionCurationQuery.matches) {
        frameId = 0;
        return;
      }

      if (!lastTime) {
        lastTime = now;
      }

      const delta = (now - lastTime) / 1000;
      lastTime = now;

      if (!isPaused && loopWidth > 0) {
        viewport.scrollLeft += direction * speed * delta;
        normalize();
      }

      frameId = window.requestAnimationFrame(tick);
    };

    const start = () => {
      measure();

      if (!frameId && !reducedMotionCurationQuery.matches) {
        frameId = window.requestAnimationFrame(tick);
      }
    };

    const stop = () => {
      window.clearTimeout(resumeTimer);

      if (frameId) {
        window.cancelAnimationFrame(frameId);
        frameId = 0;
      }
    };

    viewport.addEventListener("pointerdown", pause, { passive: true });
    viewport.addEventListener("pointerup", resumeSoon, { passive: true });
    viewport.addEventListener("pointercancel", resumeSoon, { passive: true });
    viewport.addEventListener("pointerleave", resumeSoon, { passive: true });
    viewport.addEventListener("focusin", pauseTemporarily);
    window.addEventListener("resize", measure);
    start();

    return () => {
      stop();
      viewport.removeEventListener("pointerdown", pause);
      viewport.removeEventListener("pointerup", resumeSoon);
      viewport.removeEventListener("pointercancel", resumeSoon);
      viewport.removeEventListener("pointerleave", resumeSoon);
      viewport.removeEventListener("focusin", pauseTemporarily);
      window.removeEventListener("resize", measure);
    };
  };

  const syncCurationScrollers = () => {
    document.querySelectorAll(".product-curation__viewport").forEach((viewport) => {
      if (!(viewport instanceof HTMLElement)) {
        return;
      }

      const shouldRun = mobileCurationQuery.matches && !reducedMotionCurationQuery.matches;
      const destroy = activeCurationScrollers.get(viewport);

      if (shouldRun && !destroy) {
        activeCurationScrollers.set(viewport, createCurationScroller(viewport));
      } else if (!shouldRun && destroy) {
        destroy();
        activeCurationScrollers.delete(viewport);
      }
    });
  };

  syncCurationScrollers();
  mobileCurationQuery.addEventListener("change", syncCurationScrollers);
  reducedMotionCurationQuery.addEventListener("change", syncCurationScrollers);
</script>
