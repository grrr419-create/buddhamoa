---
import type { TempleShort } from "../types";
import { socialFollowChannels } from "../data/site";
import LandingSectionPanel from "./LandingSectionPanel.astro";
import SocialFollowCta from "./SocialFollowCta.astro";
import TempleShorts from "./TempleShorts.astro";

type Props = {
  shorts: TempleShort[];
};

const { shorts } = Astro.props;
---

<LandingSectionPanel
  id="temple-shorts"
  tone="temple"
  title="잠깐, 사찰 한 바퀴"
  description="잠시 쉬어가듯, 사찰 이야기를 둘러보세요."
>
  <Fragment slot="header-actions">
    <SocialFollowCta iconOnly channels={socialFollowChannels} />
  </Fragment>
  <TempleShorts shorts={shorts} />
</LandingSectionPanel>
