---
type Props = {
  eyebrow?: string;
  title: string;
  description?: string;
};

const { eyebrow, title, description } = Astro.props;
---

<div class="section-head">
  <div class="section-head__copy">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    {description && <p class="section-head__description">{description}</p>}
  </div>
  <slot />
</div>
