---
import type { ProductShort } from "../types";
import SectionHeader from "./SectionHeader.astro";
import SocialFollowCta from "./SocialFollowCta.astro";

type Props = {
  shorts: ProductShort[];
};

const { shorts } = Astro.props;
---

<section id="product-shorts">
  <SectionHeader title="쇼츠로 보는 붓다모아 Pick">
    <SocialFollowCta
      iconOnly
      channels={[
        {
          icon: "youtube",
          href: "https://www.youtube.com/@buddha-moa?sub_confirmation=1",
          label: "유튜브",
          ctaLabel: "붓다모아 유튜브 영상 보기",
        },
        {
          icon: "instagram",
          href: "https://www.instagram.com/buddhamoa",
          label: "인스타그램",
          ctaLabel: "붓다모아 인스타그램 보기",
        },
        {
          icon: "tiktok",
          href: "https://www.tiktok.com/@buddhamoa",
          label: "틱톡",
          ctaLabel: "붓다모아 틱톡 보기",
        },
      ]}
    />
  </SectionHeader>
  <div class="temple-shorts-grid">
    {
      shorts.map((short) => (
        <article class="temple-short-card" data-track={`product_short_${short.slug}`}>
          <div class="temple-short-card__media">
            <iframe
              src={short.embedUrl}
              title={`${short.title} 쇼츠로 보는 붓다모아 Pick 영상`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            />
          </div>

          <div class="temple-short-card__body">
            <h3>{short.title}</h3>
            <a
              class="temple-short-card__buy"
              href={short.storeUrl}
              aria-label={`${short.title} 상품 보러가기`}
              data-track={`product_short_buy_${short.slug}`}
              target="_blank"
              rel="nofollow noopener noreferrer"
            >
              <span class="temple-short-card__buy-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M7.2 8.2V6.9a4.8 4.8 0 0 1 9.6 0v1.3" />
                  <path d="M5.4 8.2h13.2l-.8 11.1a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5.4 8.2Z" />
                  <path d="M8.6 11.5c.8 1.2 1.9 1.9 3.4 1.9s2.6-.7 3.4-1.9" />
                </svg>
              </span>
              <span>상품 보러가기</span>
            </a>
          </div>
        </article>
      ))
    }
  </div>
</section>
