---
import SiteViewCounter from "./SiteViewCounter.astro";
import { siteConfig } from "../data/site";
import { withBase } from "../utils/paths";
import OptimizedImage from "./OptimizedImage.astro";

type Props = {
  homeHeading?: boolean;
};

const { homeHeading = false } = Astro.props;
const BrandNameTag = homeHeading ? "h1" : "strong";
---

<header class="site-header">
  <a class="brand-mark" href={withBase("/")} aria-label={`${siteConfig.brandName} 홈으로 이동`}>
    <span class="brand-mark__icon-frame" aria-hidden="true">
      <OptimizedImage
        class="brand-mark__icon"
        src={siteConfig.brandAssetPath}
        alt=""
        width="58"
        height="58"
        loading="eager"
        fetchpriority="high"
        sizes="58px"
        optimizedWidths={[80, 160]}
        onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';"
      />
      <span class="brand-mark__sigil">연</span>
    </span>
    <span class="brand-mark__copy">
      <BrandNameTag>{siteConfig.brandName}</BrandNameTag>
      <span>{siteConfig.shortDescription}</span>
    </span>
  </a>

  <SiteViewCounter />
</header>
