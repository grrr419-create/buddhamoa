---
import type { CategoryLink } from "../types";
import { withBase } from "../utils/paths";
import OptimizedImage from "./OptimizedImage.astro";

type Props = {
  categories: CategoryLink[];
};

const { categories } = Astro.props;

const isExternalHref = (href: string) =>
  /^(?:[a-z][a-z\d+\-.]*:)?\/\//i.test(href);
---

<div class="category-link-grid">
  {categories.map((category) =>
    category.href ? (
      <a
        id={`category-${category.slug}`}
        class="category-link-card"
        href={isExternalHref(category.href) ? category.href : withBase(category.href)}
        aria-label={category.hrefLabel ? `${category.name} ${category.hrefLabel}` : `${category.name} 보기`}
        data-track={`category_${category.slug}`}
        target={isExternalHref(category.href) ? "_blank" : undefined}
        rel={isExternalHref(category.href) ? "nofollow noopener noreferrer" : undefined}
      >
        <div class="category-link-card__image-wrap">
          <OptimizedImage
            class="category-link-card__image"
            src={category.image}
            alt={category.imageAlt}
            width="720"
            height="720"
            loading="lazy"
            sizes="(max-width: 860px) 72vw, (max-width: 1040px) 30vw, 220px"
            optimizedWidths={[320, 480, 720]}
          />
        </div>
        <div class="category-link-card__meta">
          <h3>{category.name}</h3>
          <p>{category.description}</p>
          {category.hrefLabel && <span>{category.hrefLabel}</span>}
        </div>
      </a>
    ) : (
      <article id={`category-${category.slug}`} class="category-link-card">
        <div class="category-link-card__image-wrap">
          <OptimizedImage
            class="category-link-card__image"
            src={category.image}
            alt={category.imageAlt}
            width="720"
            height="720"
            loading="lazy"
            sizes="(max-width: 860px) 72vw, (max-width: 1040px) 30vw, 220px"
            optimizedWidths={[320, 480, 720]}
          />
        </div>
        <div class="category-link-card__meta">
          <h3>{category.name}</h3>
          <p>{category.description}</p>
        </div>
      </article>
    ),
  )}
</div>
