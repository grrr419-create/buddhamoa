---
import type { CategoryLink } from "../types";
import { withBase } from "../utils/paths";

type Props = {
  categories: CategoryLink[];
};

const { categories } = Astro.props;
---

<div class="category-link-grid">
  {categories.map((category) =>
    category.href ? (
      <a
        class="category-link-card"
        href={category.href}
        aria-label={`${category.name} 카테고리 보러가기`}
        data-track={`category_${category.slug}`}
      >
        <div class="category-link-card__image-wrap">
          <img
            class="category-link-card__image"
            src={withBase(category.image)}
            alt={category.imageAlt}
            width="720"
            height="720"
            loading="lazy"
          />
        </div>
      </a>
    ) : (
      <article class="category-link-card">
        <div class="category-link-card__image-wrap">
          <img
            class="category-link-card__image"
            src={withBase(category.image)}
            alt={category.imageAlt}
            width="720"
            height="720"
            loading="lazy"
          />
        </div>
      </article>
    ),
  )}
</div>
